# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# WordPress Database (for Edge Function - set in Supabase dashboard)
WC_DB_HOST=your_wordpress_db_host
WC_DB_USER=your_wordpress_db_user
WC_DB_PASSWORD=your_wordpress_db_password
WC_DB_NAME=your_wordpress_db_name
WC_DB_PORT=3306

# Razorpay Configuration (for Edge Functions - set in Supabase dashboard)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# E2E admin (optional – for scripts and Playwright; never commit password)
# See docs/E2E_ADMIN_SETUP.md. Password only in env or GitHub Secrets.
# E2E_ADMIN_EMAIL=vikram@toyflix.in
# E2E_ADMIN_PASSWORD=set_in_env_only
