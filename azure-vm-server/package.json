{
  "name": "woocommerce-api-server",
  "version": "1.0.0",
  "description": "Express.js server to serve WooCommerce data for Toyflix dashboard",
  "main": "woocommerce-server.js",
  "scripts": {
    "start": "node woocommerce-server.js",
    "dev": "nodemon woocommerce-server.js",
    "pm2:start": "pm2 start woocommerce-server.js --name woocommerce-api",
    "pm2:stop": "pm2 stop woocommerce-api",
    "pm2:restart": "pm2 restart woocommerce-api",
    "pm2:logs": "pm2 logs woocommerce-api"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "woocommerce",
    "api",
    "toyflix",
    "express",
    "mysql"
  ],
  "author": "Toyflix Team",
  "license": "MIT"
} 